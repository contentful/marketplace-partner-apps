# Secrets live in Doppler — this file is a non-secret checklist of keys only.
# Local: use `npm run start:doppler` or sync from Doppler; do not commit real values.
# See docs/current/DOPPLER.md

# ─── Contentful ───────────────────────────────────────────────
CONTENTFUL_SPACE_ID=your_space_id
CONTENTFUL_ENV_ID=master

# Management API token (required for writeback, entry fetching)
CONTENTFUL_MANAGEMENT_TOKEN=your_cma_token

# Content Delivery API token (required for CDA-first crawling)
# Create via: Contentful > Settings > API keys > Content delivery
CONTENTFUL_CDA_TOKEN=your_cda_token

# Webhook request verification (Contentful signing secret — exactly 64 characters)
# https://www.contentful.com/developers/docs/webhooks/request-verification/
# Enable "request verification" on the space webhook; verified with @contentful/node-apps-toolkit.
CONTENTFUL_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Public path Contentful POSTs to (must match signed URL; default /webhooks/contentful)
# CONTENTFUL_WEBHOOK_SIGNING_PATH=/webhooks/contentful
# Optional: previous secret while rotating
# CONTENTFUL_WEBHOOK_SECRET_PREVIOUS=
# Optional: max age of x-contentful-timestamp in seconds (default 120; 0 = disable TTL check)
# CONTENTFUL_WEBHOOK_VERIFY_TTL_SECONDS=120

# Bot user ID to prevent webhook infinite loops
# Find via: Contentful > Settings > Users > find the API key user
CONTENTFUL_BOT_USER_ID=your_bot_user_id

# ─── Google / Gemini ─────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key

# Classification model (default: gemini-3.1-pro-preview)
# GEMINI_MODEL=gemini-3.1-pro-preview

# Company search model (default: gemini-3.0-flash)
# GEMINI_SEARCH_MODEL=gemini-3.0-flash

# Judge model for LLM-as-judge script (default: gemini-2.5-flash-lite)
# GEMINI_JUDGE_MODEL=gemini-2.5-flash-lite

# ─── Classifier Tuning ───────────────────────────────────────
# Skip content hash cache (force Gemini on every run)
# CLASSIFIER_SKIP_CACHE=false

# Review thresholds (0-1)
# CLASSIFIER_REVIEW_OVERALL_THRESHOLD=0.75
# CLASSIFIER_REVIEW_SEMANTIC_THRESHOLD=0.6

# Enable confidence calibration from reviewed data
# CLASSIFIER_ENABLE_CONFIDENCE_CALIBRATION=true

# ─── Database (recommended for production queue + graph) ─────
# Without DATABASE_URL / POSTGRES_URL, webhooks classify inline (no job queue).
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# ─── Cron auth (required for /api/cron/* — Vercel Cron uses Authorization: Bearer) ─
# CRON_SECRET=your_cron_bearer_token

# ─── App Auth ─────────────────────────────────────────────────
# Shared secret for sidebar → API authentication.
# Set in Contentful app installation parameters as "appToken".
# Required in production. Also protects internal graph/feed/analytics/CRM read APIs.
# For local dev without a token, set CONTENT_GRAPH_ALLOW_UNAUTHENTICATED_DEV=true (non-production only).
# CONTENT_GRAPH_APP_TOKEN=your_random_secret_here

# Slack slash-command verification secret for /slack/cg
# SLACK_SIGNING_SECRET=your_slack_signing_secret

# ─── Vercel ──────────────────────────────────────────────────
# These are auto-set by Vercel, only needed for local dev
# VERCEL_URL=localhost:3000
