{
  "name": "@contentful/content-graph-ai",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered content taxonomy classifier and Contentful sidebar app.",
  "scripts": {
    "install-ci": "npm ci",
    "test": "npm run test:unit && npm run test:routes && npm run test:classifier && npm run test:golden",
    "test:unit": "node --import tsx tests/unit-tests.ts",
    "test:routes": "node --import tsx tests/route-tests.ts",
    "test:classifier": "node --import tsx scripts/test-classifier.ts",
    "test:repeatability": "node --import tsx scripts/check-classifier-repeatability.ts",
    "start": "node --import tsx scripts/local-dev-server.ts",
    "start:vercel": "export PATH=$PWD/scripts:$PATH && if [ -f .env.production.local ]; then dotenv -e .env.production.local -- vercel dev --yes; else dotenv -e .env.local -- vercel dev --yes; fi",
    "start:doppler": "doppler run -- node --import tsx scripts/local-dev-server.ts",
    "dev:disabled": "echo 'NOTE: npm start runs the repo-native local dev server. Use \"npm run start:vercel\" only when you explicitly want Vercel CLI emulation.'",
    "build": "node scripts/build-static.mjs",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "lint": "eslint 'api/**/*.ts' 'scripts/**/*.ts' 'tests/**/*.ts'",
    "check": "tsc",
    "test:golden": "node --import tsx scripts/golden-dataset-check.ts --min-accuracy 0.95",
    "check:format": "prettier --check '**/*.ts'",
    "format": "prettier --write '**/*.ts'",
    "docs:sync": "node scripts/sync-docs.mjs",
    "docs:check": "node scripts/sync-docs.mjs --check",
    "trace:live": "node --require dotenv/config --import tsx scripts/capture-live-classification-trace.ts",
    "trace:live:summary": "node --import tsx scripts/render-live-trace-summary.ts",
    "verify:classifier": "npm run check && npm run lint && npm run check:format && npm test && npm run check:classifier-artifacts && npm run check:classifier-governance",
    "setup-test-content": "tsx scripts/setup-test-content.ts",
    "simple-setup": "tsx scripts/simple-setup.ts",
    "scrape-contentful": "tsx scripts/scrape-contentful.ts",
    "sync:chroma": "tsx scripts/sync-corrections-to-chroma.ts",
    "calibrate:confidence": "tsx scripts/calibrate-confidence.ts",
    "generate:synthetic": "tsx scripts/generate-synthetic-research-fixtures.ts",
    "evaluate:synthetic": "tsx scripts/evaluate-synthetic-research.ts",
    "evaluate:phoenix": "node --import tsx scripts/run-phoenix-taxonomy-eval.ts",
    "sync:phoenix-prompts": "node --import tsx scripts/sync-phoenix-prompts.ts",
    "check:classifier-governance": "node scripts/check-classifier-governance.mjs",
    "check:changelog-governance": "node scripts/check-changelog-governance.mjs",
    "check:classifier-artifacts": "node --import tsx scripts/check-classifier-artifacts.ts",
    "install-app": "tsx scripts/install-app.ts",
    "create-webhook": "tsx scripts/create-webhook.ts",
    "update-webhook-url": "tsx scripts/update-webhook-url.ts",
    "update-taxonomy-latest": "tsx scripts/update-taxonomy-latest.ts"
  },
  "keywords": [],
  "type": "module",
  "author": "Zuhur Ahmed",
  "license": "ISC",
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/google-vertex": "^4.0.80",
    "@ai-sdk/openai": "^1.3.22",
    "@arizeai/phoenix-client": "^6.5.0",
    "@arizeai/phoenix-otel": "^0.4.2",
    "@contentful/node-apps-toolkit": "^3.16.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@slack/web-api": "^7.9.3",
    "@types/pg": "^8.15.5",
    "@vercel/postgres": "^0.10.0",
    "ai": "^6.0.116",
    "cheerio": "^1.1.2",
    "chromadb": "^3.3.3",
    "contentful": "^11.10.5",
    "contentful-management": "^11.54.4",
    "dotenv": "^17.2.0",
    "exa-js": "^1.8.17",
    "langsmith": "^0.5.10",
    "p-limit": "^7.1.1",
    "pg": "^8.16.3",
    "pino": "^9.9.4",
    "tsx": "^4.20.3",
    "vercel": "^39.1.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.1.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.0"
  },
  "overrides": {
    "typescript": "^5.4.5"
  }
}
