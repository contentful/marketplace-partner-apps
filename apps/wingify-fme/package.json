{
  "name": "wingify-fme",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@contentful/app-sdk": "^4.61.1",
    "@contentful/f36-components": "4.81.1",
    "@contentful/f36-tokens": "^6.1.3",
    "@contentful/react-apps-toolkit": "1.2.19",
    "contentful-management": "11.69.2",
    "emotion": "10.0.27",
    "lodash": "^4.18.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "cross-env BROWSER=none craco start",
    "build": "craco build && npm run build:functions",
    "build:functions": "contentful-app-scripts build-functions --ci",
    "test": "craco test --passWithNoTests",
    "lint": "eslint src --ext .js,.jsx",
    "eject": "react-scripts eject",
    "create-app-definition": "contentful-app-scripts create-app-definition",
    "upload": "contentful-app-scripts upload --bundle-dir ./build",
    "upload-ci": "contentful-app-scripts upload --ci --bundle-dir ./build --organization-id $CONTENTFUL_ORG_ID --definition-id $CONTENTFUL_APP_DEF_ID --token $CONTENTFUL_ACCESS_TOKEN",
    "install-ci": "npm ci",
    "deploy:staging": "contentful-app-scripts upload --ci --bundle-dir ./build --organization-id ${TEST_ORG_ID} --definition-id ${WINGIFY_STAGING_DEFINITION_ID} --token ${TEST_CMA_TOKEN}",
    "upsert-actions": "source .env && contentful-app-scripts upsert-actions"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@contentful/app-scripts": "^2.5.12",
    "@craco/craco": "^7.1.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "typescript": "4.9.5"
  },
  "homepage": "."
}