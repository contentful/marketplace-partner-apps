{
  "name": "markup-ai-contentful-app",
  "version": "1.3.1",
  "private": false,
  "homepage": ".",
  "author": "Markup AI",
  "type": "module",
  "scripts": {
    "add-locations": "contentful-app-scripts add-locations",
    "build": "npm run type-check && vite build",
    "create-app-definition": "contentful-app-scripts create-app-definition",
    "dev": "vite",
    "filter-openapi": "node scripts/filter-openapi.js",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "install-ci": "npm ci",
    "lint": "npm run lint:check",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "openapi-ts": "npm run filter-openapi && openapi-ts",
    "preview": "vite preview",
    "start": "vite",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "type-check": "tsc --project tsconfig.json --noEmit",
    "upload": "contentful-app-scripts upload --bundle-dir ./build",
    "upload-ci": "contentful-app-scripts upload --ci --bundle-dir ./build --organization-id $CONTENTFUL_ORG_ID --definition-id $CONTENTFUL_APP_DEF_ID --token $CONTENTFUL_ACCESS_TOKEN",
    "deploy": "contentful-app-scripts upload --ci --bundle-dir ./build --organization-id ${DEFINITIONS_ORG_ID} --definition-id 772aa0yka2VSPsAHnvnQ7 --token ${CONTENTFUL_CMA_TOKEN}"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "slate": "0.123.0",
    "slate-react": "0.123.0"
  },
  "dependencies": {
    "@auth0/auth0-spa-js": "2.18.0",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/merge": "6.12.1",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.41.0",
    "@contentful/app-sdk": "4.53.1",
    "@contentful/f36-components": "6.7.1",
    "@contentful/f36-tokens": "6.1.2",
    "@contentful/field-editor-markdown": "^2.0.6",
    "@contentful/field-editor-multiple-line": "^2.0.7",
    "@contentful/field-editor-rich-text": "^5.0.8",
    "@contentful/field-editor-single-line": "^2.0.7",
    "@contentful/react-apps-toolkit": "1.2.22",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@floating-ui/dom": "^1.7.6",
    "@markupai/format-offset-mapper": "^1.1.7",
    "@tanstack/react-query": "^4.43.0",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-code-block-lowlight": "^3.21.0",
    "@tiptap/pm": "^3.22.0",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "contentful-management": "11.74.0",
    "diff": "9.0.0",
    "dompurify": "3.4.9",
    "highlight.js": "^11.11.1",
    "i18next": "26.0.4",
    "js-beautify": "^1.15.4",
    "lowlight": "^3.3.0",
    "markdown-it": "14.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@contentful/app-scripts": "2.5.11",
    "@emotion/jest": "11.14.2",
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "0.94.5",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/js-beautify": "^1.14.3",
    "@types/markdown-it": "14.1.2",
    "@types/node": "25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "cross-env": "10.1.0",
    "eslint": "10.2.0",
    "jsdom": "29.0.2",
    "prettier": "3.8.1",
    "prettier-plugin-packagejson": "3.0.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.2",
    "vite": "7.3.2",
    "vitest": "4.1.4"
  }
}
