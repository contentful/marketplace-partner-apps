{
  "name": "bwx-contentful-app",
  "version": "1.2.2",
  "private": true,
  "dependencies": {
    "@contentful/app-sdk": "4.22.0",
    "@contentful/f36-components": "4.45.0",
    "@contentful/f36-icons": "^4.27.0",
    "@contentful/f36-image": "^4.81.0",
    "@contentful/f36-multiselect": "^4.23.1",
    "@contentful/f36-tokens": "4.0.2",
    "@contentful/f36-typography": "^4.61.0",
    "@contentful/react-apps-toolkit": "1.2.16",
    "contentful-management": "10.38.3",
    "emotion": "10.0.27",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router": "^6.23.0",
    "react-router-dom": "^6.23.0",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "install-ci": "npm install",
    "start": "cross-env BROWSER=none react-scripts start",
    "build:prod": "REACT_APP_LAMBDA_API=prod react-scripts build",
    "build:demo": "REACT_APP_LAMBDA_API=demo react-scripts build",
    "build:dev": "REACT_APP_LAMBDA_API=dev react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "create-app-definition": "contentful-app-scripts create-app-definition",
    "upload": "contentful-app-scripts upload --bundle-dir ./build",
    "upload-ci": "contentful-app-scripts upload --ci --bundle-dir ./build --organization-id $CONTENTFUL_ORG_ID --definition-id $CONTENTFUL_APP_DEF_ID --token $CONTENTFUL_ACCESS_TOKEN"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@contentful/app-scripts": "1.10.2",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "14.0.0",
    "@tsconfig/create-react-app": "2.0.0",
    "@types/jest": "29.5.2",
    "@types/node": "16.18.38",
    "@types/react": "18.2.14",
    "@types/react-dom": "18.2.6",
    "cross-env": "7.0.3",
    "typescript": "4.9.5"
  },
  "homepage": "."
}
